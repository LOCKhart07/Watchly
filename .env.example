# Required
TMDB_API_KEY=<your_tmdb_api_key>
TOKEN_SALT=change-me # generate a secure random string
HOST_NAME=<your_addon_url>

# App
APP_ENV="production"  # "development", "production", or "vercel"
PORT=8000
ROOT_PATH=  # subpath prefix for reverse proxy (e.g. /watchly)
ADDON_ID=com.bimal.watchly
ADDON_NAME=Watchly
ANNOUNCEMENT_HTML=

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_CONNECTIONS_THRESHOLD=100

# Tokens
TOKEN_TTL_SECONDS=0  # 0 = never expire

# Catalog updates
AUTO_UPDATE_CATALOGS=True
CATALOG_REFRESH_INTERVAL_SECONDS=86400  # 24 hours
CATALOG_CACHE_TTL=43200  # 12 hours
CATALOG_STALE_TTL=604800  # 7 days

# Recommendations
RECOMMENDATION_SOURCE_ITEMS_LIMIT=10
LIBRARY_ITEMS_LIMIT=20

# Rate limiting & caching
ENABLE_TOKEN_NEGATIVE_CACHE=True
ENABLE_TOKEN_RATE_LIMIT=True

# AI catalog name generation (optional)
GEMINI_API_KEY=<your_gemini_api_key>
DEFAULT_GEMINI_MODEL=gemma-3-27b-it
